{
    "name": "earnetics-command-center-v3",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "engines": {
        "node": ">=20.0.0 <24.0.0"
    },
    "scripts": {
        "dev": "npm run dev --workspace=packages/renderer --",
        "build": "npm run build --workspaces",
        "start": "electron packages/main/dist/index.js",
        "rebuild": "electron-rebuild"
    },
    "devDependencies": {
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@types/three": "^0.182.0",
        "electron": "^28.0.0",
        "electron-rebuild": "^3.2.9",
        "typescript": "^5.0.0",
        "vite": "^5.0.0"
    }
}