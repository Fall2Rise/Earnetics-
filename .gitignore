############################################
# Fallat_CrewAI - Monorepo .gitignore
# Windows + Python (FastAPI) + Node/React/Vite
############################################

###############
# Secrets / Env
###############
.env
.env.*
!.env.example
!.env.sample
!.env.template

secrets/
**/secrets/

*.pem
*.key
*.p12
*.pfx
*.crt

**/*apikey*
**/*api_key*
**/*token*
**/*private*

#################
# OS / Editor junk
#################
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
*.VC.VC.opendb

#######################
# Logs / Temp / Backups
#######################
*.log
**/*.log
logs/
**/logs/

tmp/
temp/
**/tmp/
**/temp/

*.tmp
*.bak
*.swp
*.swo
*.old
*.orig

# common generated reports/artifacts
*_status.txt
*_check.txt
*_verification.txt
debug_output.txt
fix_output.txt
log_output.txt

########################
# Python / Virtual Env
########################
__pycache__/
*.py[cod]
*$py.class

.pytest_cache/
.mypy_cache/
.pytype/
.ruff_cache/
.coverage
coverage/
htmlcov/
.cache/

*.egg-info/
.eggs/

# Python build artifacts
dist/
build/
pip-wheel-metadata/

# venvs (root + nested)
venv/
.venv/
**/venv/
**/.venv/

########################
# Node / Frontend deps & builds
########################
node_modules/
**/node_modules/

# build outputs
dist/
build/
**/dist/
**/build/

# Vite cache
.vite/
**/.vite/

# Next/Nuxt/etc (future-proof)
.next/
out/
.nuxt/
.svelte-kit/
.parcel-cache/
.cache/

# package manager debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/

########################
# Databases / Runtime data
########################
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sqlite3-journal

# runtime data folders (safe to ignore)
backend/data/runtime/
backend/data/cache/
backend/data/tmp/
data_backup_*/

########################
# Docker / local overrides
########################
docker-compose.override.yml

########################
# Misc
########################
*.zip
*.7z
*.tar
*.gz
*.rar

# If you intentionally want to track built frontend (generally NO), remove dist ignores above.


