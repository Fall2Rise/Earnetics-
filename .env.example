# This file contains all the environment variables used by the application.
# Copy this file to .env and fill in the values.

# Server Configuration
FALLAT_HOST=127.0.0.1
FALLAT_PORT=8000
FALLAT_RELOAD=false
FALLAT_APP_VERSION=0.1.0
ENV=development

# Security
FALLAT_API_TOKEN=

# Database Paths
BUSINESS_DB_PATH=business_database.db
AUDIT_LOG_DB=audit_log.db
VECTOR_MEMORY_DB=vector_memory.db

# LLM Providers (Legacy - will be deprecated)
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
GROK_API_KEY=
ANTHROPIC_API_KEY=
MEM0_API_KEY=

# --- NEW LLM GATEWAY CONFIGURATION ---
# Local LLM (Ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_WORKER_MODEL=llama3.1:8b
OLLAMA_STRATEGIST_MODEL=qwen2.5:14b

# Router behavior
LLM_ROUTER_ENABLED=true
LLM_MAX_CONCURRENCY=2
LLM_TIMEOUT_SECONDS=120
LLM_RETRIES=2
LLM_FALLBACK_TO_WORKER=true

# Optional future provider support
LOCAL_OAI_BASE_URL=
LOCAL_OAI_MODEL=
# -------------------------------------

# Payment Provider (Stripe)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Social & Other APIs
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
NEWS_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Affiliate Networks
AFFILIATE_API_BASE_URL=
AFFILIATE_API_KEY=
AFFILIATE_PROGRAM_ID=
CLICKBANK_API_KEY=
CLICKBANK_API_SECRET=
DIGISTORE24_API_KEY=
GUMROAD_ACCESS_TOKEN=

# Dropshipping
DROPSHIPPING_PROVIDER=
SHOPIFY_STORE_URL=
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_API_VERSION=

# Email Providers
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@earnetics.live
SMTP_SERVER=
SMTP_PORT=
SMTP_EMAIL=
SMTP_PASSWORD=

# Strategy
MAX_ACTIVE_EXPERIMENTS=3

# Rate Limiting
FALLAT_RATE_LIMIT_PER_MIN=60

# Feature Flags
ENABLE_TWITTER=false
ENABLE_GOOGLE=false
ENABLE_STRIPE=false
